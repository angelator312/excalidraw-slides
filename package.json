{
  "name": "excalidraw-slides-plugin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "server:dev": "tsx watch server/src/index.ts",
