    "test": "jest --runInBand"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.17.0",
    "@preact/preset-vite": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.0",
    "dotenv": "^16.1.4",
    "express": "^4.0.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.0",
    "mongodb": "^5.0.0",
    "nanoid": "^5.0.0",
    "preact": "^10.0.0",
    "socket.io": "^4.0.0",
    "socket.io-client": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.0",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.19.35",
    "@types/socket.io": "^3.0.2",
    "ts-jest": "^29.0.0",
    "jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^3.12.7",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts", "**/tests/**/*.integration.ts"]
